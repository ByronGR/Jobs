{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/apply/:code", "destination": "/apply.html" },
    { "source": "/jobs",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    { "source": "/firebase-config.js", "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
